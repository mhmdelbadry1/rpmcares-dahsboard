# Supabase dashboard -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Public URL where THIS backend is reachable — used to build the invite-email
# link (.../accept-invite). For local dev, http://localhost:4000 is fine as
# long as the person clicking the invite link is on the same machine.
# This exact URL must also be added in Supabase dashboard ->
# Authentication -> URL Configuration -> Redirect URLs.
APP_BASE_URL=http://localhost:4000

# Port the Express server listens on
PORT=4000

# Origin(s) allowed to call this API.
# In production, set this to your frontend domain (e.g. https://rpmcares.com).
# While developing with Expo on a separate port, use * or http://localhost:8081.
CORS_ORIGIN=*

# Absolute path to the built Expo web app (output of `npm run build:frontend`).
# Defaults to ../frontend/dist relative to wherever you run the server.
# Only needed if you deploy the frontend to a different directory.
# STATIC_DIR=/path/to/frontend/dist

# Used only by `npm run seed:superadmin` to create/update the initial super admin account
SEED_EMAIL=admin@rpmcares.local
SEED_PASSWORD=admin

# Tenovi Hardware Integration API (https://api2.tenovi.com)
# Get from: Tenovi partner portal -> API credentials
TENOVI_API_KEY=
TENOVI_CLIENT_DOMAIN=

# Tenovi RPM Clinical API — patient data, compliance, review time
# Use the portal login credentials. TOTP secret from the authenticator setup.
TENOVI_USERNAME=
TENOVI_PASSWORD=
TENOVI_TOTP_SECRET=

# SmartMeter RPM API (https://api.smartmeterrpm.com)
# Get from: SmartMeter dashboard -> API settings
SMARTMETER_API_KEY=
SMARTMETER_BASE_URL=https://api.smartmeterrpm.com

# Twilio (SMS + browser voice calling)
# Console: https://console.twilio.com
# TWILIO_ACCOUNT_SID     — Account -> Account Info -> Account SID
# TWILIO_AUTH_TOKEN      — Account -> Account Info -> Auth Token
# TWILIO_API_KEY         — API keys & tokens -> Create API key (Standard) -> SID
# TWILIO_API_SECRET      — API keys & tokens -> Create API key (Standard) -> Secret
# TWILIO_TWIML_APP_SID   — Voice -> TwiML Apps -> Create App -> set Voice URL to https://YOUR_BACKEND/api/communications/twiml
# TWILIO_FROM_NUMBER     — Phone Numbers -> Active Numbers (e.g. +12015551234)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_FROM_NUMBER=

# Gemini (Google AI Studio) — call recording transcription + AI summary.
# Get from: https://aistudio.google.com/apikey
# NOTE: this is the consumer AI Studio API, not covered by a Google BAA — call
# recordings contain PHI. Only enable this if that's been explicitly signed
# off on for this deployment; otherwise leave blank to disable the feature.
GEMINI_API_KEY=
