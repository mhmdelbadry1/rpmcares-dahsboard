{
  "name": "rpmcares-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:frontend": "cd ../frontend && npx expo export --platform web",
    "build:full": "npm run build:frontend && npm run build",
    "start": "node dist/index.js",
    "seed:superadmin": "tsx src/scripts/seed-superadmin.ts",
    "seed:clinics": "tsx src/scripts/seed-clinics.ts",
    "make:superadmin": "tsx src/scripts/make-superadmin.ts",
    "test:isolation": "tsx tests/dashboard-isolation.ts",
    "test:aggregation": "tsx tests/smartmeter-aggregation.ts",
    "sync:twilio": "tsx src/scripts/sync_twilio_history.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "node-cron": "^4.5.0",
    "twilio": "^6.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
