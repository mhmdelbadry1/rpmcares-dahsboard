# Base URL of the RPMCares Express backend.
# - iOS simulator: http://localhost:4000 works fine.
# - Android emulator: use http://10.0.2.2:4000 (localhost points at the emulator itself).
# - Physical device (Expo Go / dev build): use your computer's LAN IP, e.g. http://192.168.1.20:4000.
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
